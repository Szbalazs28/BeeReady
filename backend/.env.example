# ─── Szerver ──────────────────────────────────────────────
SERVER_IP=127.0.0.1
PORT=4000

# ─── Adatbázis (MySQL) ────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=BeeReady_db
DB_CONNECTION_LIMIT=10

# ─── JWT ──────────────────────────────────────────────────
# Generálj új titkos kulcsot:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
